# =====================================================================
#  VARIABLES DE ENTORNO DE STOCKIT
#  Copia este archivo como  ".env"  y rellena tus datos reales.
#  NUNCA subas el .env real a GitHub (ya está en .gitignore).
# =====================================================================

# Puerto (Render lo asigna solo; en local usa 3000)
PORT=3000

# Clave secreta para firmar los tokens JWT (invéntate una larga)
JWT_SECRET=cambia_esta_clave_por_una_larga_y_secreta_2026

# ---------------------------------------------------------------------
# BASE DE DATOS MySQL EN LA NUBE (Aiven)
# Copia estos datos desde el panel de tu servicio Aiven.
# ---------------------------------------------------------------------
DB_HOST=tu-servicio.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=tu_password_de_aiven
DB_DATABASE=defaultdb
DB_PORT=12345

# Pon true si tu proveedor exige SSL (Aiven = true)
DB_SSL=true
